# =====================================================================
# script_tools 项目环境变量样板
#
# 用法：
#   1. 复制本文件为 .env：    cp .env.example .env
#   2. 按需修改/填充各项；未填的字段会回落到 utils/settings.py 中的默认值
#   3. 所有"必须显式提供"的字段（密钥/账号/Cookie 等）默认无值，留空将运行
#      在受限模式（接口拒绝处理或不下发外部请求）
#
# 变量按"功能域"分组，与 utils/settings.py 中的 mixin 类一一对应。
# =====================================================================


# ─────────────── 应用层 / 基础设施 ───────────────
# Uvicorn 监听
APP_HOST=0.0.0.0
APP_PORT=2906
APP_WORKERS=4
# 用于在日志/响应里拼接对外可访问 URL 时的回退值
APP_PUBLIC_BASE_URL=http://127.0.0.1:2906

# CORS（生产环境务必收紧 CORS_ALLOW_ORIGINS）
CORS_ALLOW_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# 日志（True 表示禁用控制台输出，仅写文件，与历史默认一致）
LOG_DISABLE_CONSOLE=true
LOG_DIR=logs
LOG_BACKUP_COUNT=90

# 静态目录：相对路径会按"项目根 + STATIC_DIR"解析，避免 ./static 与 api/static 不一致
STATIC_DIR=static


# ─────────────── 数据库（PostgreSQL）───────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=root
DB_PASSWORD=
DB_NAME=script_tools_db
DB_ECHO=false


# ─────────────── RabbitMQ（暂保留，未实际启用）───────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/


# ─────────────── 公共出站 ───────────────
# 全局出站代理（任意 router 未单独配置时的回退）
# OUTBOUND_PROXY_URL=http://127.0.0.1:7890
FETCH_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# fish.audio 全局密钥（生产必须填）
# FISH_API_KEY=fa_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Cloud / Vertex / GCS 共享配置
GCP_PROJECT_ID=x-pilot-469902
GCP_LOCATION_ID=us-central1
GCS_BUCKET_NAME=x-pilot-storage
GCS_PUBLIC_URL_PREFIX=https://storage.googleapis.com/x-pilot-storage


